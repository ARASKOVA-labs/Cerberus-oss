{
  "name": "@araskova/cerberus",
  "version": "0.1.0",
  "description": "Cerberus — terminal-first agentic security framework by Araskova Labs.",
  "author": "Araskova Labs",
  "license": "UNLICENSED",
  "private": false,
  "type": "commonjs",
  "bin": {
    "cerberus": "bin/cerberus.js"
  },
  "files": [
